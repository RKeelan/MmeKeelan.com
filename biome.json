{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!dist",
      "!coverage",
      "!node_modules",
      "!src/coverage",
      "!src/node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off",
        "useArrowFunction": "off",
        "useLiteralKeys": "off",
        "useOptionalChain": "off"
      },
      "style": {
        "noParameterAssign": "off",
        "useNodejsImportProtocol": "off",
        "useNumberNamespace": "off",
        "useSingleVarDeclarator": "off",
        "useTemplate": "off"
      },
      "suspicious": {
        "noDoubleEquals": "off",
        "noGlobalIsNan": "off"
      },
      "a11y": {
        "useHtmlLang": "off",
        "useButtonType": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    },
    "globals": [
      "Image",
      "URL",
      "URLSearchParams",
      "cancelAnimationFrame",
      "clearInterval",
      "clearTimeout",
      "console",
      "document",
      "fetch",
      "requestAnimationFrame",
      "setInterval",
      "setTimeout",
      "window"
    ]
  },
  "overrides": [
    {
      "includes": ["**/*.test.js", "**/*.test.ts"],
      "javascript": {
        "globals": [
          "afterEach",
          "beforeEach",
          "describe",
          "expect",
          "it",
          "test",
          "vi"
        ]
      }
    }
  ]
}
